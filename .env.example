# ============================================
# PLANTILLA DE CONFIGURACIÓN EDU-SAAS PLATFORM
# ============================================
# COPIA ESTE ARCHIVO COMO .env Y LLENA LOS VALORES
# Nunca subas el archivo .env real a Git (contiene contraseñas)
# ============================================

# --------------------------------------------
# 1. CONFIGURACIÓN DEL SERVIDOR (BACKEND)
# --------------------------------------------
PORT=3000
PUBLIC_API_URL=http://127.0.0.1:3000

# --------------------------------------------
# 2. CONFIGURACIÓN DE BASE DE DATOS (PostgreSQL)
# --------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=edusaas_admin
DB_PASSWORD=tu_contraseña_aqui
DB_NAME=edusaas_db

# --------------------------------------------
# 3. SEGURIDAD (JWT para autenticación)
# --------------------------------------------
# Genera un secreto nuevo para producción:
# Linux/Mac: openssl rand -base64 32
# Windows: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=tu_secreto_jwt_muy_seguro

# --------------------------------------------
# 4. CONFIGURACIÓN DEL FRONTEND
# --------------------------------------------
NEXT_PUBLIC_FRONTEND_URL=http://127.0.0.1:3001
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000

# --------------------------------------------
# 5. SERVICIOS EXTERNOS (n8n para IA)
# --------------------------------------------
N8N_WEBHOOK_URL=http://127.0.0.1:5678/webhook/procesar-examen

# --------------------------------------------
# 6. MODO DE LA APLICACIÓN
# --------------------------------------------
NODE_ENV=development
